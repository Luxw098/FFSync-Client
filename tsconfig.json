{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"outDir": "dist",

		"isolatedModules": true,

		"esModuleInterop": true,
		"resolveJsonModule": true,

		"strict": true,
		"forceConsistentCasingInFileNames": true,

		"removeComments": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
