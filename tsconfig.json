{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "outDir": "dist",

        "isolatedModules": true,
        
        "esModuleInterop": true,
        "resolveJsonModule": true,
        
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        
        "removeComments": true,
        "skipLibCheck": true
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}