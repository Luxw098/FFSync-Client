{
    "manifest_version": 2,
    "name": "FFSync",
    "version": "1.0.1",
    "description": "Share Firefox tabs with other users Easily and Securely.",
    "icons": {
        "32": "assets/icon.png",
        "48": "assets/icon.png",
        "96": "assets/icon.png"
    },

    "background": {
        "scripts": ["background.js"]
    },
    "browser_action": {
        "default_icon": {
            "32": "assets/icon.png",
            "48": "assets/icon.png",
            "96": "assets/icon.png"
        },
        "default_title": "FFSync - Share Tabs",
        "default_popup": "popup/index.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ]
}
