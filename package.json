{
	"name": "ffsync",
	"private": true,
	"type": "module",
	"scripts": {
		"package": "bun run clean && tsc && bun run minify",
		"clean": "rimraf dist",
		"minify": "bun run minify:index && bun run minify:content && bun run minify:background",
		"minify:index": "esbuild dist/popup/index.js --bundle --minify --outfile=extension/popup/index.js",
		"minify:content": "esbuild dist/content.js --bundle --minify --outfile=extension/content.js",
		"minify:background": "esbuild dist/background.js --bundle --minify --outfile=extension/background.js"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"esbuild": "^0.25.6",
		"rimraf": "^6.0.1",
		"typescript": "^5"
	},
	"dependencies": {
		"ucrypt-ts": "^1.8.0"
	}
}
